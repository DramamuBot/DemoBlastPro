# =============================================
# BlastPro - Template Environment Variables
# Salin file ini menjadi .env dan isi nilainya
# =============================================

# === WAJIB DIISI ===
SECRET_KEY=ganti_dengan_random_string_panjang_dan_aman
FLASK_ENV=production

# === Supabase (Database) ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# === Keamanan Enkripsi ===
# Generate dengan: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MASTER_KEY=generate_key_baru_disini

# === Telegram API (dari my.telegram.org) ===
API_ID=123456
API_HASH=your_api_hash_here

# === Super Admin ===
SUPER_ADMIN=admin@yourdomain.com
PASS_ADMIN=password_admin_yang_kuat

# === Demo User (Opsional) ===
DEMO_USER=demo@yourdomain.com
PASS_USER=password_demo

# === Telegram Notification Bot (Opsional) ===
NOTIF_BOT_TOKEN=
NOTIF_BOT_USERNAME=
ENABLE_BOT_POLLING=false

# === Konfigurasi Aplikasi ===
APP_TIMEZONE=Asia/Jakarta
SITE_URL=https://your-app.onrender.com
